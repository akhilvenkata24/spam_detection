# Backend deployment environment variables

# Required in production
JWT_SECRET=replace-with-a-strong-random-secret
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Optional but recommended
API_KEY=replace-with-api-key-for-mobile-clients

# Comma-separated frontend origins for browser clients
# Example: https://spam-detect-frontend.onrender.com,https://your-custom-domain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Optional local seeding controls
SEED_DEMO_USER=false
DEMO_USERNAME=demo_user
DEMO_EMAIL=demo_user@test.local
DEMO_PASSWORD=Demo@123

# Hosting platform provides this automatically
PORT=5000
